# Copy to .env (git-ignored) on the NAS and fill in real values.

# Postgres password. ROTATE away from any old default — the DB port is no
# longer published to the LAN, but the password should still be strong.
# Rotating on an existing install:
#   docker compose exec db psql -U stockmanager -c "ALTER USER stockmanager PASSWORD '<new>'"
# then update this value and: docker compose up -d app
DB_PASSWORD=change-me

# Public hostname of the app. Internal DNS must point it at the NAS LAN IP.
DOMAIN=shop.example.nl

# Contact email used when manually requesting the certificate (see
# docker/renew-cert.sh) — no automated DNS provider or third-party service
# is involved; the cert is obtained by hand roughly every 60 days.
ACME_EMAIL=beheer@example.nl

# Host ports for the proxy. Keep 80/443 if free on the NAS (move the QTS
# admin UI to e.g. 8443 first). Override only if 80/443 can't be freed.
#HTTP_PORT=80
#HTTPS_PORT=443
