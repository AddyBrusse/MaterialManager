# Copy to .env (git-ignored) on the NAS and fill in real values.

# Postgres password. ROTATE away from any old default — the DB port is no
# longer published to the LAN, but the password should still be strong.
# Rotating on an existing install:
#   docker compose exec db psql -U stockmanager -c "ALTER USER stockmanager PASSWORD '<new>'"
# then update this value and: docker compose up -d app
DB_PASSWORD=change-me

# Public hostname of the app. Internal DNS must point it at the NAS LAN IP.
DOMAIN=shop.example.nl

# Contact email for the Let's Encrypt account (expiry warnings etc.).
ACME_EMAIL=beheer@example.nl

# Versio (our registrar) has no DNS-01 API, so the challenge is delegated to
# the free acme-dns service instead. One-time setup:
#   1. curl -X POST https://auth.acme-dns.io/register
#   2. Copy the response's username/password/subdomain/fulldomain below
#   3. At Versio, add this CNAME record (static, set once, never changes):
#        _acme-challenge.<your DOMAIN below>  CNAME  <fulldomain from step 2>
# Credentials from step 2 can only ever write that one challenge record —
# they have no access to any other DNS record. NEVER commit these values.
ACMEDNS_USERNAME=change-me
ACMEDNS_PASSWORD=change-me
ACMEDNS_SUBDOMAIN=change-me
ACMEDNS_SERVER_URL=https://auth.acme-dns.io

# Host ports for the proxy. Keep 80/443 if free on the NAS (move the QTS
# admin UI to e.g. 8443 first). Override only if 80/443 can't be freed.
#HTTP_PORT=80
#HTTPS_PORT=443
