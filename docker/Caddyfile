# TLS is NOT auto-managed by Caddy here — no ACME account, no DNS module,
# no third-party service ever sees any credential. Certificates are obtained
# manually (see docker/renew-cert.sh) and Caddy just serves the resulting
# files, reloading itself on restart when they're renewed.

{$DOMAIN} {
	tls /certs/live/{$DOMAIN}/fullchain.pem /certs/live/{$DOMAIN}/privkey.pem
	encode gzip
	reverse_proxy app:3000
}

# Requests that hit the NAS by raw IP or any other hostname on port 80
# (old bookmarks like http://192.168.1.x) → canonical https URL.
http:// {
	redir https://{$DOMAIN}{uri} permanent
}
