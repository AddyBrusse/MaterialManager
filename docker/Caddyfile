{
	email {$ACME_EMAIL}
	# Uncomment on first run to test against the Let's Encrypt staging CA
	# (avoids production rate limits while debugging DNS/token issues):
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$DOMAIN} {
	tls {
		# Versio has no DNS-01 API support, so ownership is proven via
		# acme-dns instead: Versio holds one static CNAME record
		# (_acme-challenge.{$DOMAIN} → the fulldomain below), and acme-dns
		# answers the actual TXT challenge using these credentials.
		dns acmedns {
			username {$ACMEDNS_USERNAME}
			password {$ACMEDNS_PASSWORD}
			subdomain {$ACMEDNS_SUBDOMAIN}
			server_url {$ACMEDNS_SERVER_URL}
		}
		# ACME propagation checks must use public DNS — the NAS's own resolver
		# is the split-horizon internal DNS and won't see the TXT record.
		resolvers 1.1.1.1
	}
	encode gzip
	reverse_proxy app:3000
}

# Requests that hit the NAS by raw IP or any other hostname on port 80
# (old bookmarks like http://192.168.1.x) → canonical https URL.
http:// {
	redir https://{$DOMAIN}{uri} permanent
}
