# Caddy with a DNS provider module for the Let's Encrypt DNS-01 challenge.
# The stock caddy image ships no DNS modules — build one in via xcaddy.
# CADDY_DNS_MODULE is set from docker-compose (docker/.env), e.g.:
#   github.com/caddy-dns/cloudflare
#   github.com/caddy-dns/transip
FROM caddy:2-builder AS builder
ARG CADDY_DNS_MODULE=github.com/caddy-dns/cloudflare
RUN xcaddy build --with ${CADDY_DNS_MODULE}

FROM caddy:2
COPY --from=builder /usr/bin/caddy /usr/bin/caddy
